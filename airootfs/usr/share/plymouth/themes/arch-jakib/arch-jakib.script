screen_width = Window.GetWidth();
screen_height = Window.GetHeight();

logo = Image("logo.png");

sprite = Sprite(logo);
sprite.SetX((screen_width / 2) - (logo.GetWidth() / 2));
sprite.SetY((screen_height / 2) - (logo.GetHeight() / 2));

progress = Sprite();
progress.SetPosition(screen_width / 2, screen_height - 200);
